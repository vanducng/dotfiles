# =============================================================================
# skhd — single source of truth for macOS hotkeys (yabai)
# Modifiers: meh = ctrl+alt+shift | hyper = ctrl+alt+shift+cmd
# =============================================================================
# Sections:
#   1. Service control
#   2. App launchers              (meh)
#   3. Window focus & warp        (ctrl/cmd+shift)
#   4. Window resize              (hyper + arrows)
#   5. Window insert              (shift+lctrl+alt)
#   6. Window float / fullscreen  (hyper)
#   7. Spaces — focus             (alt)
#   8. Spaces — send window       (hyper)
#   9. Spaces — send + follow     (cmd+ctrl)
#  10. Displays — send + follow   (cmd+ctrl + ])
#  11. Layout — balance/gaps/rotate/mirror  (hyper)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Service control
# -----------------------------------------------------------------------------
ctrl + alt + cmd - r : yabai --restart-service

# -----------------------------------------------------------------------------
# 2. App launchers (meh)
# -----------------------------------------------------------------------------
meh - a : open "/Applications/Ghostty.app"
meh - g : open "/System/Volumes/Data/Applications/Discord.app"
meh - i : open "/Applications/Structured.app"
meh - j : open "/Applications/Claude.app"
meh - k : open "/Applications/Slack.app"
meh - l : open "/Applications/Perplexity.app"
meh - p : open "/Applications/Foxit PDF Reader.app"
meh - r : open "/System/Volumes/Data/Applications/Zalo.app"
meh - s : open "/Applications/Arc.app"
meh - u : open "/Applications/Telegram.app"
meh - v : open "/Applications/Cursor.app"
meh - w : open "/Applications/LibreOffice.app"
meh - z : open "/Applications/Zen Browser.app"
# meh - 1 : open "/Applications/superwhisper.app"
# meh - b : open "/Applications/Linear.app"
# meh - d : open "/Applications/DBeaver.app"
# meh - m : open "/Applications/Firefox.app"
# meh - o : open "/Applications/Obsidian.app"
# meh - t : open "/Applications/Microsoft Teams classic.app"
# meh - x : open "/Applications/kitty.app"

# -----------------------------------------------------------------------------
# 3. Window focus & warp
# -----------------------------------------------------------------------------
ctrl + shift - h : yabai -m window --focus west
ctrl + shift - j : yabai -m window --focus south
ctrl + shift - k : yabai -m window --focus north
ctrl + shift - l : yabai -m window --focus east

cmd + shift - h : yabai -m window --warp west
cmd + shift - j : yabai -m window --warp south
cmd + shift - k : yabai -m window --warp north
cmd + shift - l : yabai -m window --warp east

# -----------------------------------------------------------------------------
# 4. Window resize (hyper + arrows)
# -----------------------------------------------------------------------------
hyper - left  : yabai -m window --resize left:-50:0;  yabai -m window --resize right:-50:0
hyper - down  : yabai -m window --resize bottom:0:50; yabai -m window --resize top:0:50
hyper - up    : yabai -m window --resize top:0:-50;   yabai -m window --resize bottom:0:-50
hyper - right : yabai -m window --resize right:50:0;  yabai -m window --resize left:50:0

# -----------------------------------------------------------------------------
# 5. Window insertion point
# -----------------------------------------------------------------------------
shift + lctrl + alt - h : yabai -m window --insert west
shift + lctrl + alt - j : yabai -m window --insert south
shift + lctrl + alt - k : yabai -m window --insert north
shift + lctrl + alt - l : yabai -m window --insert east

# -----------------------------------------------------------------------------
# 6. Window float / fullscreen
# -----------------------------------------------------------------------------
hyper - space : yabai -m window --toggle float; yabai -m window --toggle border
hyper - f     : yabai -m window --toggle zoom-fullscreen
hyper - n     : yabai -m window --toggle zoom-parent

# -----------------------------------------------------------------------------
# 7. Spaces — focus only (no window move)
# -----------------------------------------------------------------------------
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# -----------------------------------------------------------------------------
# 8. Spaces — send window without following (hyper)
# -----------------------------------------------------------------------------
hyper - tab  : yabai -m window --space recent
hyper - 1    : yabai -m window --space 1
hyper - 2    : yabai -m window --space 2
hyper - 3    : yabai -m window --space 3
hyper - 4    : yabai -m window --space 4
hyper - 5    : yabai -m window --space 5
hyper - 6    : yabai -m window --space 6
hyper - 7    : yabai -m window --space 7
hyper - 8    : yabai -m window --space 8
hyper - 9    : yabai -m window --space 9
hyper - 0x1E : yabai -m window --space next || yabai -m window --space first  # ] — wrap to first

# -----------------------------------------------------------------------------
# 9. Spaces — send window + follow + refocus (cmd+ctrl)
# -----------------------------------------------------------------------------
cmd + ctrl - p : id=$(yabai -m query --windows --window | jq .id); \
                 yabai -m window --space prev && yabai -m space --focus prev && yabai -m window --focus $id
cmd + ctrl - n : id=$(yabai -m query --windows --window | jq .id); \
                 yabai -m window --space next && yabai -m space --focus next && yabai -m window --focus $id
cmd + ctrl - m : id=$(yabai -m query --windows --window | jq .id); \
                 yabai -m window --space last && yabai -m space --focus last && yabai -m window --focus $id
cmd + ctrl - 1 : id=$(yabai -m query --windows --window | jq .id); \
                 yabai -m window --space 1 && yabai -m space --focus 1 && yabai -m window --focus $id
cmd + ctrl - 2 : id=$(yabai -m query --windows --window | jq .id); \
                 yabai -m window --space 2 && yabai -m space --focus 2 && yabai -m window --focus $id
cmd + ctrl - 3 : id=$(yabai -m query --windows --window | jq .id); \
                 yabai -m window --space 3 && yabai -m space --focus 3 && yabai -m window --focus $id
cmd + ctrl - 4 : id=$(yabai -m query --windows --window | jq .id); \
                 yabai -m window --space 4 && yabai -m space --focus 4 && yabai -m window --focus $id

# -----------------------------------------------------------------------------
# 10. Displays — send window to next display + follow + refocus (toggle)
# -----------------------------------------------------------------------------
cmd + ctrl - 0x1E : id=$(yabai -m query --windows --window | jq .id); \
                    yabai -m window --display next  || yabai -m window --display first; \
                    yabai -m display --focus next   || yabai -m display --focus first; \
                    yabai -m window --focus $id  # ]

# -----------------------------------------------------------------------------
# 11. Layout — balance / toggle gaps / rotate / mirror (hyper)
# -----------------------------------------------------------------------------
hyper - e : yabai -m space --balance
hyper - r : yabai -m space --rotate 90
hyper - x : yabai -m space --mirror x-axis
hyper - y : yabai -m space --mirror y-axis

# Toggle gaps + force external bar off
hyper - i : yabai -m space --toggle padding; \
            yabai -m space --toggle gap; \
            yabai -m config external_bar off:0:0;

# Toggle gaps only
hyper - o : yabai -m space --toggle padding; \
            yabai -m space --toggle gap;
