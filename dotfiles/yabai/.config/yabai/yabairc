#!/usr/bin/env sh
# =============================================================================
# yabai configuration
# Layout: BSP tiling | Theme: duskfox-aware borders
# =============================================================================

# -----------------------------------------------------------------------------
# Service bootstrap — load scripting addition (requires sudoers entry)
# -----------------------------------------------------------------------------
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# -----------------------------------------------------------------------------
# Layout & gaps
# -----------------------------------------------------------------------------
yabai -m config layout                      bsp
yabai -m config split_ratio                 0.50
yabai -m config auto_balance                off

yabai -m config top_padding                 5
yabai -m config bottom_padding              5
yabai -m config left_padding                5
yabai -m config right_padding               5
yabai -m config window_gap                  5

# -----------------------------------------------------------------------------
# Focus & mouse behavior
# -----------------------------------------------------------------------------
yabai -m config mouse_follows_focus         off
yabai -m config focus_follows_mouse         off
yabai -m config mouse_modifier              fn
yabai -m config mouse_action1               move
yabai -m config mouse_action2               resize

# -----------------------------------------------------------------------------
# Window visuals (borders handled by JankyBorders below)
# -----------------------------------------------------------------------------
yabai -m config window_topmost              off
yabai -m config window_opacity              off
yabai -m config window_shadow               float
yabai -m config active_window_opacity       1.0
yabai -m config normal_window_opacity       0.90
yabai -m config insert_feedback_color       0x00010101
# yabai -m config external_bar              all:5:5

# -----------------------------------------------------------------------------
# App rules — managed=off (float) unless noted
# Sorted alphabetically. Sticky+layer=above pins app on all spaces above tiles.
# -----------------------------------------------------------------------------
yabai -m rule --add app=".*"                          sub-layer=normal

# Pin apps to specific spaces (by index)
yabai -m rule --add app="^Ghostty$"                   space=1
yabai -m rule --add app="^Codex$"                     space=16
yabai -m rule --add app="^Arc$"                       space=13
yabai -m rule --add app="^Dia$"                       space=3
yabai -m rule --add app="^Claude$"                    space=4
yabai -m rule --add app="^Cursor$"                    space=5
yabai -m rule --add app="^Preview$"                   space=6
yabai -m rule --add app="^Foxit PDF Reader$"          space=6
yabai -m rule --add app="^Alter$"                     space=7 manage=off
yabai -m rule --add app="^Herd$"                      space=8
yabai -m rule --add app="^Slack$"                     space=9
yabai -m rule --add app="^Telegram$"                  space=10
yabai -m rule --add app="^Zalo$"                      space=11
yabai -m rule --add app="^Discord$"                   space=12
yabai -m rule --add app="WhatsApp$"                   space=13
yabai -m rule --add app="^Cliq$"                      space=14

# Stacked spaces — only one window visible on top, others stacked beneath
yabai -m space 3 --layout stack 2>/dev/null

# -----------------------------------------------------------------------------
# Multi-display reconcile — keep display 2 holding exactly one space (Cliq=14)
# Re-runs on monitor hot-plug via display_added / display_removed signals.
# -----------------------------------------------------------------------------
"$HOME/.config/yabai/arrange-displays.sh" &
yabai -m signal --add event=display_added \
    action="$HOME/.config/yabai/arrange-displays.sh"
yabai -m signal --add event=display_removed \
    action="$HOME/.config/yabai/arrange-displays.sh"

# Enforce app→space pinning for windows already open when yabai (re)starts.
# Rules above only fire on window creation, so existing windows would otherwise
# stay on whatever space they were on at restart. Mirror the pin rules here.
for pin in "Ghostty:1" "Codex:16" "Dia:3" "Claude:4" "Cursor:5" "Preview:6" "Foxit PDF Reader:6" "Alter:7" "Herd:8" "Slack:9" "Telegram:10" "Zalo:11" "Discord:12" "Arc:13" "Cliq:14"; do
    app="${pin%:*}"; sp="${pin#*:}"
    for id in $(yabai -m query --windows | jq -r --arg a "$app" '.[] | select(.app==$a) | .id'); do
        yabai -m window "$id" --space "$sp" 2>/dev/null
    done
done

# Force-float apps that must never be tiled (manage=off rule only fires on
# window creation; this re-floats existing windows after yabai restart).
for id in $(yabai -m query --windows | jq -r '.[] | select((.app=="Alter" or .app=="Structured") and ."is-floating"==false) | .id'); do
    yabai -m window "$id" --toggle float 2>/dev/null
done

# Sticky overlays (pinned across spaces, above tiled windows)
yabai -m rule --add app="^Activity Monitor$"          sticky=on layer=above manage=off
yabai -m rule --add app="^Disk Utility$"              sticky=on layer=above manage=off
yabai -m rule --add app="^System Information$"        sticky=on layer=above manage=off
yabai -m rule --add app="^System Preferences$"        sticky=on layer=above manage=off

# Floating apps (do not tile)
yabai -m rule --add app="^Borumi$"                    manage=off
yabai -m rule --add app="^Calculator$"                manage=off
yabai -m rule --add app="^Calendar$"                  manage=off
yabai -m rule --add app="^CleanShot X$"               manage=off
yabai -m rule --add app="^Docker Desktop$"            manage=off
yabai -m rule --add app="^FaceTime$"                  manage=off
yabai -m rule --add app="^Five9$"                     manage=off
yabai -m rule --add app="^Harvest$"                   manage=off
yabai -m rule --add app="^Installer$"                 manage=off
yabai -m rule --add app="^KeePassXC$"                 manage=off
yabai -m rule --add app="^LastPass$"                  manage=off
yabai -m rule --add app="^Messages$"                  manage=off
yabai -m rule --add app="^Microsoft Teams$"           manage=off
yabai -m rule --add app="^OpenVPN Connect$"           manage=off
yabai -m rule --add app="^Path Finder$"               manage=off
yabai -m rule --add app="^Prismatik$"                 manage=off
yabai -m rule --add app="^Private Internet Access$"   manage=off
yabai -m rule --add app="^QuickTime Player$"          manage=off
yabai -m rule --add app="^Raycast$"                   manage=off
yabai -m rule --add app="^SpaceLauncher$"             manage=off
yabai -m rule --add app="^Stats$"                     manage=off
yabai -m rule --add app="^Telegram$"                  manage=off
yabai -m rule --add app="^Time Out$"                  manage=off
yabai -m rule --add app="^Todoist$"                   manage=off
yabai -m rule --add app="^zoom.us$"                   manage=off

# -----------------------------------------------------------------------------
# Signals — fix non-native apps (LibreOffice, JetBrains, Wine) that ignore the
# initial frame call. A no-op resize forces yabai to re-issue the frame.
# -----------------------------------------------------------------------------
yabai -m signal --add event=window_created \
    action='sleep 0.3 && yabai -m window $YABAI_WINDOW_ID --resize bottom:0:0 2>/dev/null'

# Keep Alter floating even if it gets tiled after moves/space changes.
yabai -m signal --add event=window_created app="^Alter$" \
    action='sleep 0.2 && [ "$(yabai -m query --windows --window $YABAI_WINDOW_ID | jq ."is-floating")" = "false" ] && yabai -m window $YABAI_WINDOW_ID --toggle float'
yabai -m signal --add event=window_moved app="^Alter$" \
    action='[ "$(yabai -m query --windows --window $YABAI_WINDOW_ID | jq ."is-floating")" = "false" ] && yabai -m window $YABAI_WINDOW_ID --toggle float'

# Unzoom any zoom-fullscreen window when a new window appears in the same space,
# otherwise the newly opened (often same-app) window stays hidden behind the zoom.
yabai -m signal --add event=window_created \
    action='zoomed=$(yabai -m query --windows --space | jq ".[] | select(.\"has-fullscreen-zoom\" == true) | .id" | head -1); \
            if [ -n "$zoomed" ] && [ "$zoomed" != "$YABAI_WINDOW_ID" ]; then \
                yabai -m window "$zoomed" --toggle zoom-fullscreen; \
            fi'

# -----------------------------------------------------------------------------
# Companion: JankyBorders (active=bright iris, inactive=transparent bg-highlight)
# -----------------------------------------------------------------------------
borders active_color=0xffd4a4ff inactive_color=0x40393552 width=2.0 style=round 2>/dev/null &

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
yabai -m config debug_output on

echo "yabai configuration loaded.."
